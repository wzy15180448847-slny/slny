<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.houserental.mapper.PaymentRecordMapper">

    <select id="selectByUserId" resultType="com.houserental.entity.PaymentRecord">
        SELECT * FROM payment_record WHERE user_id = #{userId} ORDER BY create_time DESC
    </select>

    <select id="selectByOrderNo" resultType="com.houserental.entity.PaymentRecord">
        SELECT * FROM payment_record WHERE order_no = #{orderNo}
    </select>

</mapper>
